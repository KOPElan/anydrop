@inject ISecureTokenStorage TokenStorage
@inject IServerConfigService ServerConfig
@inject NavigationManager Nav

@if (!_initialized)
{
    <div class="flex h-screen items-center justify-center bg-gray-50 dark:bg-gray-900">
        <div class="flex flex-col items-center gap-3">
            <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
            <span class="text-sm text-gray-400 dark:text-gray-500">正在加载...</span>
        </div>
    </div>
}
else
{
    <Router AppAssembly="typeof(Routes).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
}

@code {
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        // 检测外部分享内容
        if (PendingShareStore.HasContent)
        {
            if (await TokenStorage.IsAuthenticatedAsync())
                Nav.NavigateTo("/share");
            else
                Nav.NavigateTo("/login?returnTo=/share");
            _initialized = true;
            return;
        }

        // 检测通知深链接
        if (PendingShareStore.NotificationTopicId.HasValue)
        {
            var topicId = PendingShareStore.NotificationTopicId.Value;
            PendingShareStore.NotificationTopicId = null;
            if (await TokenStorage.IsAuthenticatedAsync())
            {
                Nav.NavigateTo($"/?topicId={topicId}");
                _initialized = true;
                return;
            }
        }

        // 正常启动路由决策：必须先确认 BaseUrl 已配置，再决定去哪里
        if (!ServerConfig.HasBaseUrl())
        {
            Nav.NavigateTo("/setup");
            _initialized = true;
            return;
        }

        if (!await TokenStorage.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            _initialized = true;
            return;
        }

        _initialized = true;
    }
}

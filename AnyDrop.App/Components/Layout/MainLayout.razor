@inherits LayoutComponentBase
@inject AppEventBus EventBus
@inject NavigationManager Nav
@inject IConnectivityService Connectivity
@implements IDisposable

<div class="flex flex-col h-screen bg-gray-50 dark:bg-gray-900 overflow-hidden">
    @if (_showOfflineBanner)
    {
        <div class="bg-yellow-500 text-white text-center text-sm py-1 px-4 transition-all">
            📡 无网络连接
        </div>
    }
    @if (_signalRDisconnected)
    {
        <div class="bg-orange-400 text-white text-center text-sm py-1 px-4">
            🔄 实时连接断开，正在重连...
        </div>
    }

    <main class="flex-1 overflow-hidden">
        @Body
    </main>

    <nav class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 flex justify-around items-center h-14 safe-area-bottom">
        <NavLink href="/" Match="NavLinkMatch.All" class="flex flex-col items-center text-xs gap-0.5 text-gray-500 dark:text-gray-400 active:text-indigo-600" ActiveClass="text-indigo-600 dark:text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            <span>主页</span>
        </NavLink>
        <NavLink href="/search" class="flex flex-col items-center text-xs gap-0.5 text-gray-500 dark:text-gray-400 active:text-indigo-600" ActiveClass="text-indigo-600 dark:text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span>搜索</span>
        </NavLink>
        <NavLink href="/settings" class="flex flex-col items-center text-xs gap-0.5 text-gray-500 dark:text-gray-400 active:text-indigo-600" ActiveClass="text-indigo-600 dark:text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>设置</span>
        </NavLink>
    </nav>
</div>

@code {
    private bool _showOfflineBanner;
    private bool _signalRDisconnected;

    protected override void OnInitialized()
    {
        EventBus.AuthExpired += OnAuthExpired;
        EventBus.ConnectivityChanged += OnConnectivityChanged;
        _showOfflineBanner = !Connectivity.IsOnline;
    }

    private void OnAuthExpired()
    {
        InvokeAsync(() =>
        {
            Nav.NavigateTo("/login", forceLoad: false);
        });
    }

    private void OnConnectivityChanged(bool isOnline)
    {
        InvokeAsync(() =>
        {
            _showOfflineBanner = !isOnline;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        EventBus.AuthExpired -= OnAuthExpired;
        EventBus.ConnectivityChanged -= OnConnectivityChanged;
    }
}


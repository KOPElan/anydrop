@inject ITopicService TopicService
@inject IAppStateService AppState

<div class="flex flex-col h-full p-2 gap-1">
    <div class="flex justify-between items-center px-2 py-1">
        <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">主题</span>
        <button @onclick="ShowCreateDialogAsync" class="text-indigo-600 dark:text-indigo-400 text-xs font-medium">+ 新建</button>
    </div>

    @foreach (var topic in AppState.Topics.Where(t => !t.IsArchived).OrderByDescending(t => t.IsPinned).ThenBy(t => t.SortOrder))
    {
        <div @onclick="() => SelectTopic(topic.Id)"
             draggable="true"
             @ondragstart="() => _dragId = topic.Id"
             @ondragover:preventDefault="true"
             @ondrop="() => OnDrop(topic.Id)"
             class="flex items-center gap-2 px-3 py-2.5 rounded-xl cursor-pointer transition-colors @(AppState.CurrentTopicId == topic.Id ? "bg-indigo-50 dark:bg-indigo-900/30" : "hover:bg-gray-100 dark:hover:bg-gray-700/50")">
            <span class="text-xl">@topic.Icon</span>
            <div class="flex-1 min-w-0">
                <div class="font-medium text-sm text-gray-800 dark:text-gray-100 truncate">@topic.Name</div>
                @if (topic.IsPinned)
                {
                    <div class="text-xs text-indigo-400">📌 置顶</div>
                }
            </div>
            <button @onclick:stopPropagation="true" @onclick="() => OpenActionMenu(topic)"
                    class="text-gray-400 dark:text-gray-500 hover:text-gray-600 p-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M6 10a2 2 0 11-4 0 2 2 0 014 0zM12 10a2 2 0 11-4 0 2 2 0 014 0zM16 12a2 2 0 100-4 2 2 0 000 4z" />
                </svg>
            </button>
        </div>
    }

    <div class="mt-2">
        <button @onclick="() => _showArchived = !_showArchived"
                class="text-xs text-gray-400 dark:text-gray-500 px-3 flex items-center gap-1">
            <span>@(_showArchived ? "▾" : "▸")</span> 已归档主题
        </button>
        @if (_showArchived)
        {
            @foreach (var topic in AppState.Topics.Where(t => t.IsArchived))
            {
                <div @onclick="() => SelectTopic(topic.Id)"
                     class="flex items-center gap-2 px-3 py-2 rounded-xl cursor-pointer opacity-60 hover:opacity-80 hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-all">
                    <span class="text-lg">@topic.Icon</span>
                    <span class="flex-1 text-sm text-gray-700 dark:text-gray-300 truncate">@topic.Name</span>
                </div>
            }
        }
    </div>

    @if (_showCreateDialog)
    {
        <div class="fixed inset-0 z-50 flex items-end justify-center bg-black/50">
            <div class="bg-white dark:bg-gray-800 rounded-t-2xl w-full max-w-lg p-6 space-y-4">
                <h3 class="font-semibold text-gray-800 dark:text-gray-100">新建主题</h3>
                <input @bind="_newTopicName" type="text" placeholder="主题名称"
                       class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <div class="flex gap-3">
                    <button @onclick="() => _showCreateDialog = false"
                            class="flex-1 py-2.5 border border-gray-300 dark:border-gray-600 rounded-xl text-gray-700 dark:text-gray-300">取消</button>
                    <button @onclick="CreateTopicAsync"
                            class="flex-1 py-2.5 bg-indigo-600 text-white rounded-xl font-medium">创建</button>
                </div>
            </div>
        </div>
    }

    @if (_actionMenuTopic is not null)
    {
        <TopicActionMenu Topic="_actionMenuTopic" OnClose="() => _actionMenuTopic = null" OnTopicChanged="LoadTopicsAsync" />
    }
</div>

@code {
    [Parameter] public EventCallback<Guid> OnTopicSelected { get; set; }

    private bool _showArchived;
    private bool _showCreateDialog;
    private string _newTopicName = string.Empty;
    private TopicDto? _actionMenuTopic;
    private Guid? _dragId;

    private void SelectTopic(Guid id) => OnTopicSelected.InvokeAsync(id);

    private void OpenActionMenu(TopicDto topic) => _actionMenuTopic = topic;

    private Task ShowCreateDialogAsync()
    {
        _newTopicName = string.Empty;
        _showCreateDialog = true;
        return Task.CompletedTask;
    }

    private async Task CreateTopicAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTopicName)) return;
        var topic = await TopicService.CreateTopicAsync(new CreateTopicRequest(_newTopicName));
        AppState.Topics.Add(topic);
        AppState.NotifyStateChanged();
        _showCreateDialog = false;
        _newTopicName = string.Empty;
    }

    private async Task LoadTopicsAsync()
    {
        var topics = await TopicService.GetTopicsAsync();
        AppState.Topics.Clear();
        foreach (var t in topics) AppState.Topics.Add(t);
        AppState.NotifyStateChanged();
    }

    private async Task OnDrop(Guid targetId)
    {
        if (_dragId is null || _dragId == targetId) return;
        var items = AppState.Topics.Where(t => !t.IsArchived).OrderByDescending(t => t.IsPinned).ThenBy(t => t.SortOrder).ToList();
        var dragIdx = items.FindIndex(t => t.Id == _dragId);
        var dropIdx = items.FindIndex(t => t.Id == targetId);
        if (dragIdx < 0 || dropIdx < 0) return;

        var item = items[dragIdx];
        items.RemoveAt(dragIdx);
        items.Insert(dropIdx, item);

        var reorder = new ReorderTopicsRequest(items.Select((t, i) => new TopicOrderItem(t.Id, i)).ToList());
        await TopicService.ReorderTopicsAsync(reorder);
        await LoadTopicsAsync();
        _dragId = null;
    }
}

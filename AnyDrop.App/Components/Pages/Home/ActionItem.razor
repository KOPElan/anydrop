<button @onclick="OnClick"
        class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors text-left @(Danger ? "text-red-600 dark:text-red-400" : "text-gray-700 dark:text-gray-300")">
    <span>@Icon</span>
    <span class="text-sm font-medium">@Label</span>
</button>

@code {
    [Parameter] public string Icon { get; set; } = string.Empty;
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public bool Danger { get; set; }
}

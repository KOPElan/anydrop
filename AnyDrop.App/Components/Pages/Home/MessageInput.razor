@inject IShareService ShareService
@inject IFileUploadService FileUploadService
@inject IPickerService Picker
@inject IAppStateService AppState

<div class="border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 px-3 py-2">
    @if (_uploading)
    {
        <div class="mb-2">
            <div class="h-1 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-500 transition-all duration-300" style="width: @((_uploadProgress * 100).ToString("F0"))%"></div>
            </div>
            <p class="text-xs text-gray-500 mt-0.5">上传中 @((_uploadProgress * 100).ToString("F0"))%</p>
        </div>
    }

    <div class="flex items-end gap-2">
        <div class="flex gap-1">
            <button @onclick="PickFileAndUploadAsync" disabled="@_uploading"
                    class="p-2 text-gray-500 dark:text-gray-400 hover:text-indigo-600 disabled:opacity-40">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                </svg>
            </button>
            <button @onclick="PickPhotoAndUploadAsync" disabled="@_uploading"
                    class="p-2 text-gray-500 dark:text-gray-400 hover:text-indigo-600 disabled:opacity-40">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </button>
        </div>

        <textarea @bind="_text" @onkeydown="OnKeyDown"
                  placeholder="发送消息..."
                  rows="1"
                  class="flex-1 px-3 py-2 rounded-xl border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-sm text-gray-900 dark:text-gray-100 resize-none focus:outline-none focus:ring-2 focus:ring-indigo-500 max-h-32 overflow-y-auto"></textarea>

        <button @onclick="SendTextAsync"
                disabled="@(string.IsNullOrWhiteSpace(_text) || _uploading)"
                class="p-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 disabled:opacity-40 transition-colors flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter] public Guid TopicId { get; set; }

    private string _text = string.Empty;
    private bool _uploading;
    private double _uploadProgress;

    private async Task SendTextAsync()
    {
        if (string.IsNullOrWhiteSpace(_text)) return;
        var textToSend = _text;
        _text = string.Empty;
        var item = await ShareService.SendTextAsync(new CreateTextShareItemRequest(TopicId, textToSend));
        AppState.Messages.Add(item);
        AppState.NotifyStateChanged();
    }

    private async Task PickFileAndUploadAsync()
    {
        var picked = await Picker.PickFileAsync();
        if (picked is null) return;
        await UploadAsync(picked.Value.Stream, picked.Value.FileName, picked.Value.MimeType);
    }

    private async Task PickPhotoAndUploadAsync()
    {
        var picked = await Picker.PickPhotoAsync();
        if (picked is null) return;
        await UploadAsync(picked.Value.Stream, picked.Value.FileName, picked.Value.MimeType);
    }

    private async Task UploadAsync(Stream stream, string fileName, string mimeType)
    {
        _uploading = true;
        _uploadProgress = 0;
        var progress = new Progress<double>(p => { _uploadProgress = p; InvokeAsync(StateHasChanged); });
        try
        {
            var item = await FileUploadService.UploadFileAsync(stream, fileName, mimeType, TopicId, progress);
            AppState.Messages.Add(item);
            AppState.NotifyStateChanged();
        }
        finally
        {
            _uploading = false;
            _uploadProgress = 0;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendTextAsync();
    }
}

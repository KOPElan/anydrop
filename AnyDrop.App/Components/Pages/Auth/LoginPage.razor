@page "/login"
@layout AuthLayout
@inject IAuthService AuthService
@inject ISignalRService SignalR
@inject INotificationService Notifications
@inject NavigationManager Nav

<div class="space-y-4">
    <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-100">登录</h2>

    <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">密码</label>
        <input @bind="_password"
               type="password"
               placeholder="输入您的密码"
               class="w-full px-4 py-3 rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
    </div>

    @if (_error is not null)
    {
        <p class="text-red-500 text-sm">@_error</p>
    }

    <button @onclick="LoginAsync"
            disabled="@(_loading || string.IsNullOrWhiteSpace(_password))"
            class="w-full py-3 bg-indigo-600 text-white rounded-xl font-medium hover:bg-indigo-700 disabled:opacity-50 transition-colors">
        @(_loading ? "登录中..." : "登录")
    </button>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnTo { get; set; }

    private string _password = string.Empty;
    private string? _error;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        var status = await AuthService.GetSetupStatusAsync();
        if (status.RequiresSetup)
            Nav.NavigateTo("/setup-account");
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_password)) return;
        _loading = true;
        _error = null;

        var result = await AuthService.LoginAsync(new LoginRequest(_password));
        if (result.Success)
        {
            await Notifications.RequestPermissionAsync();
            await SignalR.StartAsync();
            Nav.NavigateTo(ReturnTo ?? "/");
        }
        else
        {
            _error = result.Error ?? "密码错误，请重试。";
            _loading = false;
        }
    }
}

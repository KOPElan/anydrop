@page "/Error"
@using System.Diagnostics
@using AnyDrop.Resources
@inject IStringLocalizer<SharedStrings> L

<PageTitle>@L["Error_PageTitle"]</PageTitle>

<h1 class="text-danger">@L["Error_Title"]</h1>
<h2 class="text-danger">@L["Error_Description"]</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@L["Error_RequestId"]</strong> <code>@RequestId</code>
    </p>
}

<h3>@L["Error_DevelopmentMode"]</h3>
<p>
    @L["Error_DevelopmentHint"]
</p>
<p>
    @L["Error_ProductionWarning"]
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

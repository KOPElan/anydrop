@page "/"

<PageTitle>@(_selectedTopicName ?? "AnyDrop")</PageTitle>

@*
    聊天主区域：使用 relative + absolute 定位让顶部标题栏和底部输入框
    始终悬浮于消息列表之上，实现真正的磨砂玻璃遮罩效果。
    消息列表 absolute inset-0 overflow-y-auto，通过 padding-top/bottom 留出空间。
*@
<section @ref="_chatSectionRef"
         class="relative h-full overflow-hidden bg-surface"
         @ondragover:preventDefault>

    @* ─────────── 顶部标题栏（磨砂玻璃效果，absolute 定位覆盖消息列表）─────────── *@
    <header class="absolute inset-x-0 top-0 z-40 flex items-center justify-between px-6 py-4 chat-header-glass">
        <div class="flex items-center gap-3">
            <h2 class="font-headline font-bold text-on-surface text-lg leading-tight">
                @(_selectedTopicName ?? "选择主题")
            </h2>
        </div>
        @if (_selectedTopicId.HasValue)
        {
            <button type="button"
                    class="flex h-9 w-9 items-center justify-center rounded-full text-on-surface-variant transition-colors hover:bg-surface-container active:scale-90"
                    title="主题设置"
                    @onclick="OpenTopicSettingsModal">
                <span class="material-symbols-outlined" style="font-size: 20px;">build</span>
            </button>
        }
    </header>

    @* ─────────── 消息列表（覆盖整个 section，顶/底留出玻璃栏高度）─────────── *@
    <div @ref="_messageListRef"
         id="message-list"
         class="absolute inset-0 overflow-y-auto px-6 space-y-6 chat-message-list">
        @if (!_selectedTopicId.HasValue)
        {
            <div class="flex h-full flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">chat_bubble_outline</span>
                <p class="mt-4 text-sm font-medium text-on-surface-variant">请先在左侧选择一个主题</p>
            </div>
        }
        else if (_messages.Count == 0)
        {
            <div class="flex h-full flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">chat_bubble_outline</span>
                <p class="mt-4 text-sm font-medium text-on-surface-variant">暂无内容，发送第一条消息吧</p>
            </div>
        }
        else
        {
            @* 消息按时间升序排列，最新的在最底部 *@
            @foreach (var message in _messages)
            {
                var isBurnMessage = message.ExpiresAt.HasValue;
                var bubbleClass = isBurnMessage ? "burn-after-reading" : "";
                <div class="flex flex-col items-start max-w-2xl message-bubble @bubbleClass" @key="message.Id">
                    @switch (message.ContentType)
                    {
                        case ShareContentType.Link:
                            <div class="bubble-link bg-surface-container-lowest p-5 rounded-2xl max-w-full transition-all duration-150">
                                <div class="flex items-center gap-2 text-primary mb-3">
                                    <span class="material-symbols-outlined text-sm">link</span>
                                    <span class="text-xs font-semibold uppercase tracking-wide">链接</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(message.LinkTitle))
                                {
                                    <h4 class="text-sm font-semibold text-on-surface mb-1 leading-snug">@message.LinkTitle</h4>
                                }
                                @if (!string.IsNullOrWhiteSpace(message.LinkDescription))
                                {
                                    <p class="text-xs text-on-surface-variant mb-3 leading-relaxed line-clamp-2">@message.LinkDescription</p>
                                }
                                <div class="flex items-center gap-2 flex-wrap">
                                    <a class="text-xs text-on-surface-variant break-all underline underline-offset-2 opacity-70 hover:opacity-100 flex-1 min-w-0 truncate"
                                       href="@message.Content"
                                       target="_blank"
                                       rel="noopener noreferrer">@message.Content</a>
                                    <a class="flex items-center gap-1.5 text-xs font-semibold text-white px-3 py-1.5 rounded-full transition-all active:scale-95 shrink-0"
                                       style="background: linear-gradient(135deg, #0050cb, #0066ff);"
                                       href="@message.Content"
                                       target="_blank"
                                       rel="noopener noreferrer">
                                        <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'FILL' 1;">open_in_new</span>
                                        打开链接
                                    </a>
                                </div>
                            </div>
                            break;

                        case ShareContentType.Image:
                            <div class="bubble-file bg-surface-container-lowest p-3 rounded-2xl shadow-sm transition-all duration-150">
                                @* 点击图片在 Modal 中预览原图 *@
                                <div class="rounded-xl overflow-hidden mb-3 cursor-zoom-in"
                                     @onclick="() => OpenImagePreview(GetFileUrl(message.Id))">
                                    <img class="max-h-72 w-full object-contain transition-transform duration-200 hover:scale-[1.02]"
                                         src="@GetFileUrl(message.Id)"
                                         alt="@message.FileName" />
                                </div>
                                <div class="flex items-center justify-between px-1">
                                    <div class="flex items-center gap-3">
                                        <div class="p-2 bg-primary-fixed rounded-lg text-primary">
                                            <span class="material-symbols-outlined text-lg">image</span>
                                        </div>
                                        <div>
                                            <h4 class="font-semibold text-sm text-on-surface">@(message.FileName ?? "图片")</h4>
                                            @if (message.FileSize.HasValue)
                                            {
                                                <p class="text-[11px] text-on-surface-variant">@FormatFileSize(message.FileSize.Value)</p>
                                            }
                                        </div>
                                    </div>
                                    <a href="@GetFileUrl(message.Id, true)"
                                       class="p-2 text-on-surface-variant hover:text-primary transition-colors">
                                        <span class="material-symbols-outlined">download</span>
                                    </a>
                                </div>
                            </div>
                            break;

                        case ShareContentType.Video:
                            <div class="bubble-file bg-surface-container-lowest p-3 rounded-2xl shadow-sm w-full max-w-lg transition-all duration-150">
                                <div class="rounded-xl overflow-hidden mb-3">
                                    <video class="w-full max-h-64 rounded-xl bg-on-surface"
                                           controls
                                           src="@GetFileUrl(message.Id)"></video>
                                </div>
                                <div class="flex items-center justify-between px-1">
                                    <div class="flex items-center gap-3">
                                        <div class="p-2 bg-primary-fixed rounded-lg text-primary">
                                            <span class="material-symbols-outlined text-lg">videocam</span>
                                        </div>
                                        <div>
                                            <h4 class="font-semibold text-sm text-on-surface">@(message.FileName ?? "视频")</h4>
                                            @if (message.FileSize.HasValue)
                                            {
                                                <p class="text-[11px] text-on-surface-variant">@FormatFileSize(message.FileSize.Value)</p>
                                            }
                                        </div>
                                    </div>
                                    <a href="@GetFileUrl(message.Id, true)"
                                       class="p-2 text-on-surface-variant hover:text-primary transition-colors">
                                        <span class="material-symbols-outlined">download</span>
                                    </a>
                                </div>
                            </div>
                            break;

                        case ShareContentType.File:
                            <div class="bubble-file bg-surface-container-lowest p-4 rounded-2xl shadow-sm flex items-center justify-between gap-4 w-full max-w-md transition-all duration-150">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 bg-error-container/30 flex items-center justify-center rounded-xl text-error">
                                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">description</span>
                                    </div>
                                    <div>
                                        <h4 class="font-semibold text-sm text-on-surface">@(message.FileName ?? "附件")</h4>
                                        @if (message.FileSize.HasValue)
                                        {
                                            <p class="text-[11px] text-on-surface-variant">@FormatFileSize(message.FileSize.Value)</p>
                                        }
                                    </div>
                                </div>
                                <a href="@GetFileUrl(message.Id, true)"
                                   class="p-2 text-on-surface-variant hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined">download</span>
                                </a>
                            </div>
                            break;

                        default:
                            <div class="bubble-text bg-surface-container-lowest p-5 rounded-2xl transition-all duration-150">
                                <p class="text-sm text-on-surface leading-relaxed whitespace-pre-wrap break-words">@message.Content</p>
                            </div>
                            break;
                    }
                    @* 消息时间：显示完整日期 + 时间，阅后即焚时额外显示倒计时 *@
                    <div class="mt-2 ml-1 flex items-center gap-2 text-[11px] font-bold text-primary">
                        <span class="material-symbols-outlined" style="font-size: 12px;">schedule</span>
                        @FormatMessageTime(message.CreatedAt)
                        @if (message.ExpiresAt.HasValue)
                        {
                            <span class="flex items-center gap-0.5 rounded-full px-1.5 py-0.5 text-[10px] font-semibold"
                                  style="background: var(--color-error-container, #ffdad6); color: var(--color-error, #ba1a1a);">
                                <span class="material-symbols-outlined" style="font-size: 10px; font-variation-settings: 'FILL' 1;">timer</span>
                                @FormatExpiry(message.ExpiresAt.Value)
                            </span>
                        }
                    </div>
                </div>
            }
        }
    </div>

    @* ─────────── 拖放覆盖层（纯视觉提示）─────────── *@
    @if (_isDragging)
    {
        <div class="absolute inset-0 z-30 flex flex-col items-center justify-center gap-4 pointer-events-none"
             style="background: rgba(0,80,203,0.08); backdrop-filter: blur(4px);">
            <div class="flex flex-col items-center gap-3 text-primary">
                <span class="material-symbols-outlined text-6xl" style="font-variation-settings: 'FILL' 1;">upload_file</span>
                <p class="text-lg font-bold font-headline">松开即可发送文件</p>
            </div>
        </div>
    }

    @* ─────────── 图片大图预览 Modal ─────────── *@
    @if (_previewImageUrl is not null)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/80"
             @onclick="CloseImagePreview">
            <button type="button"
                    class="absolute top-4 right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-white hover:bg-white/30 transition-colors"
                    @onclick:stopPropagation
                    @onclick="CloseImagePreview">
                <span class="material-symbols-outlined">close</span>
            </button>
            <img class="max-h-[90vh] max-w-[90vw] rounded-xl object-contain shadow-2xl"
                 src="@_previewImageUrl"
                 alt="图片预览"
                 @onclick:stopPropagation />
        </div>
    }

    @* ─────────── 主题设置 Modal ─────────── *@
    @if (_showTopicSettingsModal)
    {
        <div class="modal-overlay" @onclick="CloseTopicSettingsModal">
            <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modal-topic-settings-title" @onclick:stopPropagation>
                <h3 id="modal-topic-settings-title" class="modal-title">主题设置</h3>

                @* 改名 *@
                <div class="mt-4">
                    <label class="text-xs font-semibold text-on-surface-variant mb-1 block">主题名称</label>
                    <div class="flex gap-2">
                        <input class="flex-1 rounded-xl border px-3 py-2 text-sm outline-none transition focus:ring-2 focus:ring-primary/30"
                               style="border-color: var(--color-outline-variant); background: var(--color-surface); color: var(--color-on-surface);"
                               maxlength="100"
                               @bind="_topicSettingsName"
                               @ref="_topicSettingsInputRef" />
                        <button type="button" class="btn-primary shrink-0" @onclick="SaveTopicNameAsync">保存</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_topicSettingsError))
                    {
                        <p class="mt-1 text-xs" style="color: var(--color-error);">@_topicSettingsError</p>
                    }
                </div>

                @* 主题图标 *@
                <div class="mt-4">
                    <label class="text-xs font-semibold text-on-surface-variant mb-1 block">主题图标</label>
                    <div class="grid grid-cols-6 gap-2">
                        @foreach (var icon in _availableIcons)
                        {
                            var isSelected = _topicSettingsIcon == icon;
                            <button type="button"
                                    class="flex items-center justify-center p-2 rounded-lg transition-all @(isSelected ? "ring-2 ring-primary" : "hover:bg-surface-container")"
                                    style="@(isSelected ? "background: var(--color-primary-fixed);" : "")"
                                    @onclick="() => SelectIcon(icon)">
                                <span class="material-symbols-outlined text-lg"
                                      style="color: @(isSelected ? "var(--color-primary)" : "var(--color-on-surface-variant)");">@icon</span>
                            </button>
                        }
                    </div>
                    <button type="button" class="btn-primary mt-2 w-full" @onclick="SaveTopicIconAsync">保存图标</button>
                </div>

                @* 分隔线 *@
                <div class="my-4 border-t" style="border-color: var(--color-outline-variant);"></div>

                @* 操作按钮 *@
                <div class="space-y-2">
                    @* 置顶 / 取消置顶 *@
                    <button type="button"
                            class="flex w-full items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-colors hover:bg-surface-container"
                            style="color: var(--color-on-surface-variant);"
                            @onclick="TogglePinCurrentTopicAsync">
                        <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' @(_selectedTopicPinned ? "1" : "0");">bookmark</span>
                        @(_selectedTopicPinned ? "取消置顶" : "置顶主题")
                    </button>

                    @* 归档 / 取消归档 *@
                    <button type="button"
                            class="flex w-full items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-colors hover:bg-surface-container"
                            style="color: var(--color-on-surface-variant);"
                            @onclick="ArchiveCurrentTopicAsync">
                        <span class="material-symbols-outlined text-base">@(_selectedTopicArchived ? "unarchive" : "archive")</span>
                        @(_selectedTopicArchived ? "取消归档" : "归档主题")
                    </button>

                    @* 删除（仅在无内容时可操作）*@
                    @if (_selectedTopicMessageCount == 0 && !_selectedTopicIsBuiltIn)
                    {
                        <button type="button"
                                class="flex w-full items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition-colors hover:bg-error-container/20"
                                style="color: var(--color-error);"
                                @onclick="DeleteCurrentTopicAsync">
                            <span class="material-symbols-outlined text-base">delete</span>
                            删除主题
                        </button>
                    }
                    else if (!_selectedTopicIsBuiltIn && _selectedTopicMessageCount > 0)
                    {
                        <div class="flex items-center gap-3 rounded-xl px-4 py-3 text-sm opacity-40 cursor-not-allowed"
                             style="color: var(--color-error);" title="主题有消息时无法删除，请先归档">
                            <span class="material-symbols-outlined text-base">delete</span>
                            删除主题（有内容，不可删除）
                        </div>
                    }
                </div>

                <div class="modal-actions mt-4">
                    <button type="button" class="btn-secondary" @onclick="CloseTopicSettingsModal">关闭</button>
                </div>
            </div>
        </div>
    }

    @* ─────────── 输入区（磨砂玻璃效果，absolute 定位覆盖消息列表底部）─────────── *@
    <footer class="absolute inset-x-0 bottom-0 z-40 p-4 chat-footer-glass">
        <div class="flex items-end gap-3 bg-surface-container-lowest p-3 rounded-[2rem]"
             style="box-shadow: 0 8px 32px rgba(25,28,29,0.06);">
            @* 附件按钮 *@
            <div class="flex gap-1 px-1 mb-1">
                <label class="flex cursor-pointer items-center justify-center rounded-full p-2 text-on-surface-variant transition-colors hover:bg-surface-container active:scale-90"
                       title="上传图片或视频">
                    <span class="material-symbols-outlined">image</span>
                    <InputFile class="hidden" multiple accept="image/*,video/*" OnChange="OnFilesSelected" />
                </label>
                <label class="flex cursor-pointer items-center justify-center rounded-full p-2 text-on-surface-variant transition-colors hover:bg-surface-container active:scale-90"
                       title="上传附件">
                    <span class="material-symbols-outlined">attachment</span>
                    <InputFile class="hidden" multiple OnChange="OnFilesSelected" />
                </label>
                @* 阅后即焚切换按钮 *@
                <button type="button"
                        class="flex items-center justify-center rounded-full p-2 transition-all active:scale-90 @(_burnAfterReading ? "text-error" : "text-on-surface-variant hover:bg-surface-container")"
                        style="@(_burnAfterReading ? "background: var(--color-error-container, #ffdad6);" : "")"
                        title="@(_burnAfterReading ? "阅后即焚已开启（10分钟后自动删除）" : "开启阅后即焚")"
                        @onclick="ToggleBurnAfterReading">
                    <span class="material-symbols-outlined"
                          style="font-variation-settings: 'FILL' @(_burnAfterReading ? 1 : 0);">
                        timer
                    </span>
                </button>
            </div>

            @* 文本输入 *@
            <div class="flex-1 min-w-0">
                <textarea class="w-full resize-none bg-transparent py-2 px-2 text-sm text-on-surface outline-none placeholder:text-on-surface-variant/50"
                          style="border: none; max-height: 8rem; field-sizing: content;"
                          placeholder="输入消息，或拖入文件到聊天区域…（Ctrl+Enter 发送）"
                          maxlength="10000"
                          rows="1"
                          @bind="_inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"></textarea>
                @if (!string.IsNullOrWhiteSpace(_validationError))
                {
                    <p class="px-2 text-xs text-error">@_validationError</p>
                }
            </div>

            @* 发送按钮 *@
            <div class="mb-1 mr-1">
                <button type="button"
                        class="flex h-10 w-10 items-center justify-center rounded-full text-white shadow-md transition-all active:scale-90 disabled:opacity-50"
                        style="background: linear-gradient(135deg, #0050cb, #0066ff);"
                        disabled="@_isSending"
                        @onclick="SendAsync">
                    <span class="material-symbols-outlined font-bold"
                          style="font-variation-settings: 'FILL' 1;">arrow_upward</span>
                </button>
            </div>
        </div>
        <p class="mt-3 text-center text-[10px] font-medium text-on-surface-variant opacity-50">
            拖放文件到聊天区域可快速发送
        </p>
    </footer>

</section>



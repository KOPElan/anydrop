@page "/"
@attribute [Authorize]

<PageTitle>@(_selectedTopicName ?? "AnyDrop")</PageTitle>

@*
    聊天主区域：使用 relative + absolute 定位让顶部标题栏和底部输入框
    始终悬浮于消息列表之上，实现真正的磨砂玻璃遮罩效果。
    消息列表 absolute inset-0 overflow-y-auto，通过 padding-top/bottom 留出空间。
*@
<section @ref="_chatSectionRef"
         class="relative h-full overflow-hidden"
         @ondragover:preventDefault>

    @* ─────────── 顶部标题栏（磨砂玻璃效果，absolute 定位覆盖消息列表）─────────── *@
    <header class="absolute inset-x-0 top-0 z-40 flex h-20 items-center justify-between px-8 chat-header-glass">
        <div class="flex items-center gap-3">
            @* 移动端菜单按钮（桌面端隐藏）*@
            <button type="button"
                    class="sidebar-menu-toggle h-9 w-9 items-center justify-center rounded-full text-on-surface-variant transition-colors hover:bg-white/40 active:scale-90"
                    title="@L["Home_OpenMenu"]"
                    @onclick="() => ToggleMobileSidebar?.Invoke()">
                <span class="material-symbols-outlined" style="font-size: 22px;">menu</span>
            </button>
            <div>
                <h2 class="font-headline text-2xl font-extrabold tracking-tight leading-none" style="color: var(--color-on-surface);">
                    @(_selectedTopicName ?? L["Home_SelectTopic"])
                </h2>
                @if (_selectedTopicId.HasValue)
                {
                    <p class="text-[11px] font-medium uppercase tracking-wider mt-1" style="color: var(--color-outline);">@L["Home_SessionStorage"]</p>
                }
            </div>
        </div>
        @if (_selectedTopicId.HasValue)
        {
            <div class="flex items-center gap-1">
                @* 搜索按钮 *@
                <a href="/search/@_selectedTopicId"
                   class="flex h-10 w-10 items-center justify-center rounded-full transition-colors hover:bg-white/40 active:scale-90"
                   style="color: var(--color-on-surface-variant);"
                         title="@L["Home_SearchTopic"]">
                    <span class="material-symbols-outlined" style="font-size: 20px;">search</span>
                </a>
                @* 主题操作下拉菜单 *@
                <div class="relative">
                    <button type="button"
                            class="flex h-10 w-10 items-center justify-center rounded-full transition-colors hover:bg-white/40 active:scale-90"
                            style="color: var(--color-on-surface-variant);"
                            title="@L["Home_MoreActions"]"
                            @onclick="ToggleTopicMenu"
                            @onclick:stopPropagation>
                        <span class="material-symbols-outlined" style="font-size: 20px;">more_vert</span>
                    </button>
                    @* 下拉菜单面板 *@
                    @if (_showTopicMenu)
                    {
                        <div class="topic-menu-panel" @onclick:stopPropagation>
                            @* 主题信息 *@
                            <button type="button" class="topic-menu-item" @onclick="OpenTopicInfoModal">
                                <span class="material-symbols-outlined topic-menu-item__icon">info</span>
                                <span class="flex-1">@L["Home_TopicInfo"]</span>
                            </button>
                            @* 置顶（带开关）*@
                            <button type="button" class="topic-menu-item" @onclick="TogglePinCurrentTopicAsync">
                                <span class="material-symbols-outlined topic-menu-item__icon"
                                      style="font-variation-settings: 'FILL' @(_selectedTopicPinned ? "1" : "0");">bookmark</span>
                                  <span class="flex-1">@(_selectedTopicPinned ? L["Home_Unpin"] : L["Home_Pin"])</span>
                                @* 开关状态指示 *@
                                <span class="topic-menu-toggle @(_selectedTopicPinned ? "topic-menu-toggle--on" : "")">
                                    <span class="topic-menu-toggle__knob"></span>
                                </span>
                            </button>
                            @* 归档（带开关）*@
                            <button type="button" class="topic-menu-item" @onclick="ArchiveCurrentTopicAsync">
                                <span class="material-symbols-outlined topic-menu-item__icon">@(_selectedTopicArchived ? "unarchive" : "archive")</span>
                                <span class="flex-1">@(_selectedTopicArchived ? L["Home_Unarchive"] : L["Home_Archive"])</span>
                                <span class="topic-menu-toggle @(_selectedTopicArchived ? "topic-menu-toggle--on" : "")">
                                    <span class="topic-menu-toggle__knob"></span>
                                </span>
                            </button>
                            @* 分割线 *@
                            <div class="my-1" style="border-top: 1px solid var(--color-outline-variant);"></div>
                            @* 删除 *@
                            @if (_selectedTopicIsBuiltIn)
                            {
                                <div class="topic-menu-item topic-menu-item--disabled"
                                     role="menuitem" aria-disabled="true"
                                     title="@L["Home_BuiltInCannotDelete"]">
                                    <span class="material-symbols-outlined topic-menu-item__icon">delete</span>
                                    <span class="flex-1">@L["Common_Delete"]</span>
                                    <span class="text-[10px]" style="color: var(--color-outline);">@L["Home_BuiltInTag"]</span>
                                </div>
                            }
                            else if (_selectedTopicMessageCount > 0)
                            {
                                <div class="topic-menu-item topic-menu-item--disabled"
                                     role="menuitem" aria-disabled="true"
                                     title="@L["Home_NotEmptyCannotDelete"]">
                                    <span class="material-symbols-outlined topic-menu-item__icon">delete</span>
                                    <span class="flex-1">@L["Common_Delete"]</span>
                                    <span class="text-[10px]" style="color: var(--color-outline);">@L["Home_HasContentTag"]</span>
                                </div>
                            }
                            else
                            {
                                <button type="button" class="topic-menu-item topic-menu-item--danger" @onclick="ConfirmDeleteCurrentTopic">
                                    <span class="material-symbols-outlined topic-menu-item__icon">delete</span>
                                    <span class="flex-1">@L["Common_Delete"]</span>
                                </button>
                            }
                        </div>
                        @* 点击菜单外关闭 *@
                        <div class="fixed inset-0 z-50" role="presentation" aria-hidden="true" @onclick="CloseTopicMenu"></div>
                    }
                </div>
            </div>
        }
    </header>

    @* ─────────── 消息列表（覆盖整个 section，顶/底留出玻璃栏高度）─────────── *@
    <div @ref="_messageListRef"
         id="message-list"
         class="absolute inset-0 overflow-y-auto px-6 space-y-6 chat-message-list">
        @if (!_selectedTopicId.HasValue)
        {
            <div class="flex h-full flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">chat_bubble_outline</span>
                <p class="mt-4 text-sm font-medium text-on-surface-variant">@L["Home_EmptySelectTopic"]</p>
            </div>
        }
        else if (_messages.Count == 0)
        {
            <div class="flex h-full flex-col items-center justify-center text-center">
                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30">chat_bubble_outline</span>
                <p class="mt-4 text-sm font-medium text-on-surface-variant">@L["Home_EmptySendFirst"]</p>
            </div>
        }
        else
        {
            @* 消息按时间升序排列，最新的在最底部 *@
            <div class="max-w-4xl mx-auto w-full">
            @foreach (var message in _messages)
            {
                var isBurnMessage = message.ExpiresAt.HasValue;
                var bubbleClass = isBurnMessage ? "burn-after-reading" : "";
                <div class="flex flex-col items-start max-w-2xl message-bubble m-6 @bubbleClass" @key="message.Id" data-message-id="@message.Id">
                    @switch (message.ContentType)
                    {
                        case ShareContentType.Link:
                                <div class="bubble-link bg-surface-container-lowest p-3 rounded-3xl rounded-tl-lg shadow-sm max-w-full transition-all duration-150">
                                <div class="flex items-center gap-2 text-primary mb-3">
                                    <span class="material-symbols-outlined text-sm">link</span>
                                    <span class="text-xs font-semibold uppercase tracking-wide">@L["Home_Link"]</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(message.LinkTitle))
                                {
                                    <h4 class="text-sm font-semibold text-on-surface mb-1 leading-snug">@message.LinkTitle</h4>
                                }
                                @if (!string.IsNullOrWhiteSpace(message.LinkDescription))
                                {
                                    <p class="text-xs text-on-surface-variant mb-3 leading-relaxed line-clamp-2">@message.LinkDescription</p>
                                }
                                <div class="flex items-center gap-2 flex-wrap">
                                    <a class="text-xs text-on-surface-variant break-all underline underline-offset-2 opacity-70 hover:opacity-100 flex-1 min-w-0 truncate"
                                       href="@message.Content"
                                       target="_blank"
                                       rel="noopener noreferrer">@message.Content</a>
                                    <a class="flex items-center gap-1.5 text-xs font-semibold text-white px-3 py-1.5 rounded-full transition-all active:scale-95 shrink-0"
                                       style="background: linear-gradient(135deg, #0050cb, #0066ff);"
                                       href="@message.Content"
                                       target="_blank"
                                       rel="noopener noreferrer">
                                        <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'FILL' 1;">open_in_new</span>
                                        @L["Home_OpenLink"]
                                    </a>
                                </div>
                            </div>
                            break;

                        case ShareContentType.Image:
                                <div class="bubble-text p-3 rounded-3xl rounded-tl-lg max-w-lg transition-all duration-150">
                                @* 点击图片在 Modal 中预览原图 *@
                                <div class="rounded-xl overflow-hidden mb-3 cursor-zoom-in"
                                     @onclick="() => OpenImagePreview(GetFileUrl(message.Id))">
                                    <img class="max-h-72 w-full object-contain transition-transform duration-200 hover:scale-[1.02]"
                                         src="@GetFileUrl(message.Id)"
                                         alt="@message.FileName" />
                                </div>
                                <div class="flex items-center justify-between px-1">
                                    <div class="flex items-center gap-3">
                                        <div class="p-2 rounded-lg bg-white/20">
                                            <span class="material-symbols-outlined text-lg text-white">image</span>
                                        </div>
                                        <div>
                                            <h4 class="font-semibold text-sm text-white">@(message.FileName ?? L["Home_Image"])</h4>
                                            @if (message.FileSize.HasValue)
                                            {
                                                <p class="text-[11px] text-white/70">@FormatFileSize(message.FileSize.Value)</p>
                                            }
                                        </div>
                                    </div>
                                    <a href="@GetFileUrl(message.Id, true)"
                                       class="p-2 text-white/70 hover:text-white transition-colors">
                                        <span class="material-symbols-outlined">download</span>
                                    </a>
                                </div>
                            </div>
                            break;

                        case ShareContentType.Video:
                                <div class="bubble-text p-3 rounded-3xl rounded-tl-lg w-full max-w-lg transition-all duration-150">
                                <div class="rounded-xl overflow-hidden mb-3">
                                    <video class="w-full max-h-64 rounded-xl"
                                           controls
                                           src="@GetFileUrl(message.Id)"></video>
                                </div>
                                <div class="flex items-center justify-between px-1">
                                    <div class="flex items-center gap-3">
                                        <div class="p-2 rounded-lg bg-white/20">
                                            <span class="material-symbols-outlined text-lg text-white">videocam</span>
                                        </div>
                                        <div>
                                            <h4 class="font-semibold text-sm text-white">@(message.FileName ?? L["Home_Video"])</h4>
                                            @if (message.FileSize.HasValue)
                                            {
                                                <p class="text-[11px] text-white/70">@FormatFileSize(message.FileSize.Value)</p>
                                            }
                                        </div>
                                    </div>
                                    <a href="@GetFileUrl(message.Id, true)"
                                       class="p-2 text-white/70 hover:text-white transition-colors">
                                        <span class="material-symbols-outlined">download</span>
                                    </a>
                                </div>
                            </div>
                            break;

                        case ShareContentType.File:
                                <div class="bubble-text px-5 py-4 rounded-3xl rounded-tl-lg flex items-center gap-4 w-full max-w-md transition-all duration-150">
                                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/20 flex-shrink-0">
                                    <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">description</span>
                                </div>
                                <div class="min-w-0 flex-1">
                                    <h4 class="font-semibold text-sm text-white truncate">@(message.FileName ?? L["Home_File"])</h4>
                                    @if (message.FileSize.HasValue)
                                    {
                                        <p class="text-[11px] text-white/70">@FormatFileSize(message.FileSize.Value)</p>
                                    }
                                </div>
                                <a href="@GetFileUrl(message.Id, true)"
                                   class="p-2 text-white/70 hover:text-white flex-shrink-0 transition-colors">
                                    <span class="material-symbols-outlined">download</span>
                                </a>
                            </div>
                            break;

                        default:
                            <div class="bubble-text px-6 py-4 rounded-3xl rounded-tl-lg transition-all duration-150 max-w-md">
                                <p class="text-[15px] font-medium leading-relaxed whitespace-pre-wrap break-words text-white">@message.Content</p>
                            </div>
                            break;
                    }
                    @* 消息时间：圆点指示 + 完整日期时间，阅后即焚时额外显示倒计时 *@
                    <div class="mt-3 flex items-center gap-1.5 text-[11px] font-semibold pl-2" style="color: var(--color-outline);">
                        <span class="inline-block w-1.5 h-1.5 rounded-full flex-shrink-0" style="background-color: rgba(59,130,246,0.50);"></span>
                        <span>@FormatMessageTime(message.CreatedAt)</span>
                        @if (message.ExpiresAt.HasValue)
                        {
                            <span class="ml-1 flex items-center gap-0.5 rounded-full px-1.5 py-0.5 text-[10px] font-semibold"
                                  style="color: var(--color-error, #ba1a1a);">
                                <span class="material-symbols-outlined" style="font-size: 10px; font-variation-settings: 'FILL' 1;">timer</span>
                                @FormatExpiry(message.ExpiresAt.Value)
                            </span>
                        }
                    </div>
                </div>
            }
            </div>
        }
    </div>

    @* ─────────── 拖放覆盖层（纯视觉提示）─────────── *@
    @if (_isDragging)
    {
        <div class="absolute inset-0 z-30 flex flex-col items-center justify-center gap-4 pointer-events-none"
             style="background: rgba(0,80,203,0.08); backdrop-filter: blur(4px);">
            <div class="flex flex-col items-center gap-3 text-primary">
                <span class="material-symbols-outlined text-6xl" style="font-variation-settings: 'FILL' 1;">upload_file</span>
                <p class="text-lg font-bold font-headline">@L["Home_DropToSend"]</p>
            </div>
        </div>
    }

    @* ─────────── 图片大图预览 Modal ─────────── *@
    @if (_previewImageUrl is not null)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/80"
             @onclick="CloseImagePreview">
            <button type="button"
                    class="absolute top-4 right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-white hover:bg-white/30 transition-colors"
                    @onclick:stopPropagation
                    @onclick="CloseImagePreview">
                <span class="material-symbols-outlined">close</span>
            </button>
            <img class="max-h-[90vh] max-w-[90vw] rounded-xl object-contain shadow-2xl"
                 src="@_previewImageUrl"
                  alt="@L["Home_ImagePreview"]"
                 @onclick:stopPropagation />
        </div>
    }

    @* ─────────── 主题信息 Modal（独立子组件，避免图标选择触发整体重渲染）─────────── *@
    <TopicSettingsModal Visible="_showTopicSettingsModal"
                        InitialName="@(_topicSettingsName)"
                        InitialIcon="@(_topicSettingsIcon)"
                        AvailableIcons="_availableIcons"
                        Error="@_topicSettingsError"
                        OnClose="CloseTopicSettingsModal"
                        OnSave="HandleTopicInfoSave" />

    @* ─────────── 删除主题二次确认 Modal ─────────── *@
    @if (_showDeleteConfirmModal)
    {
        <div class="modal-overlay" @onclick="CancelDeleteConfirm">
            <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modal-delete-confirm-title" @onclick:stopPropagation>
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full" style="background: var(--color-error-container);">
                        <span class="material-symbols-outlined" style="color: var(--color-error);">delete_forever</span>
                    </div>
                    <h3 id="modal-delete-confirm-title" class="modal-title mb-0">@L["Home_ConfirmDeleteTitle"]</h3>
                </div>
                <p class="text-sm text-on-surface-variant">@L["Home_ConfirmDeleteMessage", _selectedTopicName ?? string.Empty]</p>
                <div class="modal-actions mt-4">
                    <button type="button" class="btn-secondary" @onclick="CancelDeleteConfirm">@L["Common_Cancel"]</button>
                    <button type="button"
                            class="rounded-xl px-4 py-2 text-sm font-medium text-white transition-colors"
                            style="background: var(--color-error);"
                            @onclick="DeleteCurrentTopicAsync">@L["Home_ConfirmDeleteAction"]</button>
                </div>
            </div>
        </div>
    }

    @* ─────────── 输入区（渐出遮罩 + 浮动玻璃卡片）─────────── *@
    <footer class="absolute inset-x-0 bottom-0 z-40 px-6 pb-6 pt-6 chat-footer-glass" style="pointer-events: none;">
        <div class="mx-auto max-w-4xl" style="pointer-events: auto;">
        <div class="input-wrapper chat-input-card px-4 py-3">
            @* 附件按钮（带右侧分割线）*@
            <div class="input-actions pr-3" style="border-right: 1px solid rgba(203,213,225,0.50);">
                <label class="flex cursor-pointer items-center justify-center rounded-xl p-2.5 transition-colors hover:bg-blue-50 active:scale-90"
                       style="color: var(--color-on-surface-variant);"
                      title="@L["Home_UploadImageOrVideo"]">
                        <span class="material-symbols-outlined text-base">image</span>
                    <InputFile class="hidden" multiple accept="image/*,video/*" OnChange="OnFilesSelected" />
                </label>
                <label class="flex cursor-pointer items-center justify-center rounded-xl p-2.5 transition-colors hover:bg-blue-50 active:scale-90"
                       style="color: var(--color-on-surface-variant);"
                      title="@L["Home_UploadAttachment"]">
                        <span class="material-symbols-outlined text-base">attach_file</span>
                    <InputFile class="hidden" multiple OnChange="OnFilesSelected" />
                </label>
                @* 阅后即焚切换按钮 *@
                <button type="button"
                        class="flex items-center justify-center rounded-xl p-2.5 transition-all active:scale-90 @(_burnAfterReading ? "text-error" : "hover:bg-blue-50")"
                        style="color: @(_burnAfterReading ? "var(--color-error)" : "var(--color-on-surface-variant)"); @(_burnAfterReading ? "background: var(--color-error-container, #ffdad6);" : "")"
                    title="@(_burnAfterReading ? L["Home_BurnOnHint"] : L["Home_BurnOffHint"])"
                        @onclick="ToggleBurnAfterReading">
                        <span class="material-symbols-outlined text-base"
                          style="font-variation-settings: 'FILL' @(_burnAfterReading ? 1 : 0);">
                        timer
                    </span>
                </button>
            </div>

            @* 文本输入 *@
            <div class="input-textarea-wrap">
                <textarea class="w-full resize-none bg-transparent py-2 px-4 text-[15px] font-medium outline-none"
                          style="border: none; max-height: 8rem; field-sizing: content; color: var(--color-on-surface);"
                          placeholder="@L["Home_InputPlaceholder"]"
                          maxlength="10000"
                          rows="1"
                          @bind="_inputText"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"></textarea>
                @if (!string.IsNullOrWhiteSpace(_validationError))
                {
                    <p class="px-4 text-xs text-error">@_validationError</p>
                }
            </div>

            @* 发送按钮（方形，渐变）*@
            <div class="input-send-wrap ml-2">
                <button type="button"
                        class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl text-white transition-all hover:scale-105 active:scale-95 disabled:opacity-50"
                        style="background: linear-gradient(135deg, #6366f1, #3b82f6); box-shadow: 0 4px 12px rgba(99,102,241,0.35);"
                        disabled="@_isSending"
                        @onclick="SendAsync">
                    <span class="material-symbols-outlined"
                          style="font-size: 20px; font-variation-settings: 'FILL' 1;">arrow_upward</span>
                </button>
            </div>
        </div>
        </div>
    </footer>

</section>


@page "/settings"
@attribute [Authorize]

<PageTitle>设置 - AnyDrop</PageTitle>

<section class="mx-auto mt-10 w-full max-w-2xl space-y-6 px-4">
    <div class="rounded-2xl border border-gray-200 bg-white p-6">
        <h2 class="text-lg font-semibold">账号设置</h2>
        <div class="mt-4 grid gap-4">
            <div>
                <label class="mb-1 block text-sm font-medium">昵称</label>
                <InputText @bind-Value="_nickname" class="w-full rounded-xl border border-gray-300 px-3 py-2" />
            </div>
            <button type="button" class="w-fit rounded-xl bg-blue-600 px-4 py-2 text-white" @onclick="SaveNicknameAsync">保存昵称</button>
        </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6">
        <h2 class="text-lg font-semibold">修改密码</h2>
        <div class="mt-4 grid gap-4">
            <InputText @bind-Value="_currentPassword" type="password" class="w-full rounded-xl border border-gray-300 px-3 py-2" placeholder="当前密码" />
            <InputText @bind-Value="_newPassword" type="password" class="w-full rounded-xl border border-gray-300 px-3 py-2" placeholder="新密码" />
            <InputText @bind-Value="_confirmPassword" type="password" class="w-full rounded-xl border border-gray-300 px-3 py-2" placeholder="确认新密码" />
            <button type="button" class="w-fit rounded-xl bg-blue-600 px-4 py-2 text-white" @onclick="SavePasswordAsync">更新密码</button>
        </div>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6">
        <h2 class="text-lg font-semibold">安全设置</h2>
        <div class="mt-4 flex items-center justify-between">
            <p class="text-sm text-gray-700">自动获取链接预览</p>
            <input type="checkbox" @bind="_autoFetchLinkPreview" />
        </div>
        <button type="button" class="mt-4 w-fit rounded-xl bg-blue-600 px-4 py-2 text-white" @onclick="SaveSecurityAsync">保存安全设置</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="text-sm text-emerald-600">@_message</p>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="text-sm text-red-600">@_error</p>
    }
</section>

@page "/settings"
@attribute [Authorize]

<PageTitle>@L["Settings_Title"] - AnyDrop</PageTitle>

<div class="relative h-full flex flex-col overflow-hidden">
    @* 顶部标题栏，含后退按钮 *@
    <header class="shrink-0 z-40 flex items-center gap-3 px-4 py-3 chat-header-glass">
        <button type="button"
                class="flex h-9 w-9 items-center justify-center rounded-full text-on-surface-variant transition-colors hover:bg-surface-container active:scale-90"
                title="@L["Nav_Back"]"
                @onclick="GoBack">
            <span class="material-symbols-outlined" style="font-size: 22px;">arrow_back</span>
        </button>
        <h1 class="font-headline font-bold text-on-surface text-lg leading-tight">@L["Settings_Title"]</h1>
    </header>

    <div class="flex-1 overflow-y-auto">
        <section class="mx-auto mt-6 w-full max-w-2xl space-y-6 px-4 pb-10">

            @* ── 账号设置 ── *@
            <div class="settings-card">
                <h2 class="settings-section-title">@L["Settings_Account"]</h2>
                <div class="mt-4 grid gap-4">
                    <div>
                        <label class="settings-label">@L["Settings_Nickname"]</label>
                        <InputText @bind-Value="_nickname" class="settings-input w-full" />
                    </div>
                    <button type="button" class="btn-primary w-fit" @onclick="SaveNicknameAsync">@L["Settings_SaveNickname"]</button>
                </div>
            </div>

            @* ── 修改密码 ── *@
            <div class="settings-card">
                <h2 class="settings-section-title">@L["Settings_ChangePassword"]</h2>
                <div class="mt-4 grid gap-4">
                    <InputText @bind-Value="_currentPassword" type="password" class="settings-input w-full" placeholder="@L["Settings_CurrentPassword"]" />
                    <InputText @bind-Value="_newPassword" type="password" class="settings-input w-full" placeholder="@L["Settings_NewPassword"]" />
                    <InputText @bind-Value="_confirmPassword" type="password" class="settings-input w-full" placeholder="@L["Settings_ConfirmPassword"]" />
                    <button type="button" class="btn-primary w-fit" @onclick="SavePasswordAsync">@L["Settings_UpdatePassword"]</button>
                </div>
            </div>

            @* ── 系统设置 ── *@
            <div class="settings-card">
                <h2 class="settings-section-title">@L["Settings_Security"]</h2>
                <div class="mt-4 space-y-5">

                    @* 自动获取链接预览 *@
                    <div class="settings-row">
                        <p class="text-sm font-medium text-on-surface">@L["Settings_AutoFetchLink"]</p>
                        <button type="button"
                                class="topic-menu-toggle @(_autoFetchLinkPreview ? "topic-menu-toggle--on" : "")"
                                @onclick="() => _autoFetchLinkPreview = !_autoFetchLinkPreview"
                                aria-pressed="@_autoFetchLinkPreview">
                            <span class="topic-menu-toggle__knob"></span>
                        </button>
                    </div>

                    @* 暗色主题 *@
                    <div class="settings-row">
                        <div>
                            <p class="text-sm font-medium text-on-surface">@L["Settings_DarkMode"]</p>
                            <p class="text-xs text-on-surface-variant/70">@L["Settings_DarkModeHint"]</p>
                        </div>
                        <button type="button"
                                class="topic-menu-toggle @(_isDarkMode ? "topic-menu-toggle--on" : "")"
                                @onclick="ToggleThemeAsync"
                                aria-pressed="@_isDarkMode">
                            <span class="topic-menu-toggle__knob"></span>
                        </button>
                    </div>

                    @* 阅后即焚时长 *@
                    <div>
                        <label class="settings-label">@L["Settings_BurnDuration"]</label>
                        <p class="mb-1.5 text-xs text-on-surface-variant/70">@L["Settings_BurnDurationHint"]</p>
                        <input type="number"
                               class="settings-input w-full"
                               min="1"
                               max="43200"
                               @bind="_burnAfterReadingMinutes" />
                    </div>

                    @* 语言设置 *@
                    <div>
                        <label class="settings-label">@L["Settings_Language"]</label>
                        <select class="settings-input w-full" @bind="_language">
                            <option value="zh-CN">@L["Lang_ZhCN"]</option>
                            <option value="zh-TW">@L["Lang_ZhTW"]</option>
                            <option value="en">@L["Lang_En"]</option>
                        </select>
                    </div>

                    <button type="button" class="btn-primary w-fit" @onclick="SaveSecurityAsync">@L["Settings_SaveSecurity"]</button>
                </div>
            </div>

            @* ── 消息管理 ── *@
            <div class="settings-card">
                <h2 class="settings-section-title">@L["Settings_MessageManagement"]</h2>
                <div class="mt-4 space-y-5">

                    @* 手动清理 *@
                    <div>
                        <p class="text-sm font-medium text-on-surface">@L["Settings_ManualCleanup"]</p>
                        <p class="mb-3 text-xs text-on-surface-variant/70">@L["Settings_ManualCleanupHint"]</p>
                        <div class="flex flex-wrap gap-2">
                            <button type="button" class="btn-secondary text-sm" disabled="@_isCleaningUp" @onclick="() => RequestCleanup(1)">@L["Settings_Cleanup1Month"]</button>
                            <button type="button" class="btn-secondary text-sm" disabled="@_isCleaningUp" @onclick="() => RequestCleanup(3)">@L["Settings_Cleanup3Months"]</button>
                            <button type="button" class="btn-secondary text-sm" disabled="@_isCleaningUp" @onclick="() => RequestCleanup(6)">@L["Settings_Cleanup6Months"]</button>
                        </div>
                    </div>

                    @* 自动清理开关 *@
                    <div class="settings-row">
                        <div>
                            <p class="text-sm font-medium text-on-surface">@L["Settings_AutoCleanup"]</p>
                            <p class="text-xs text-on-surface-variant/70">@L["Settings_AutoCleanupHint"]</p>
                        </div>
                        <button type="button"
                                class="topic-menu-toggle @(_autoCleanupEnabled ? "topic-menu-toggle--on" : "")"
                                @onclick="() => _autoCleanupEnabled = !_autoCleanupEnabled"
                                aria-pressed="@_autoCleanupEnabled">
                            <span class="topic-menu-toggle__knob"></span>
                        </button>
                    </div>

                    @* 自动清理阈值 *@
                    @if (_autoCleanupEnabled)
                    {
                        <div>
                            <label class="settings-label">@L["Settings_AutoCleanupMonths"]</label>
                            <select class="settings-input w-full" @bind="_autoCleanupMonths">
                                <option value="1">@L["Settings_AutoCleanupMonths1"]</option>
                                <option value="3">@L["Settings_AutoCleanupMonths3"]</option>
                                <option value="6">@L["Settings_AutoCleanupMonths6"]</option>
                            </select>
                        </div>
                    }

                    <button type="button" class="btn-primary w-fit" @onclick="SaveSecurityAsync">@L["Settings_SaveSecurity"]</button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="flex items-center gap-2 rounded-2xl px-4 py-3" style="background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.25);">
                    <span class="material-symbols-outlined text-emerald-600" style="font-size: 18px;">check_circle</span>
                    <p class="text-sm text-emerald-700">@_message</p>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="flex items-center gap-2 rounded-2xl px-4 py-3" style="background: rgba(186, 26, 26, 0.08); border: 1px solid rgba(186, 26, 26, 0.2);">
                    <span class="material-symbols-outlined" style="font-size: 18px; color: var(--color-error);">error</span>
                    <p class="text-sm" style="color: var(--color-error);">@_error</p>
                </div>
            }
        </section>
    </div>
</div>

@* ── 手动清理二次确认 Modal ── *@
@if (_showCleanupConfirmModal)
{
    <div class="modal-overlay" @onclick="CancelCleanupConfirm">
        <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modal-cleanup-confirm-title" @onclick:stopPropagation>
            <div class="flex items-center gap-3 mb-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full" style="background: var(--color-error-container);">
                    <span class="material-symbols-outlined" style="color: var(--color-error);">delete_sweep</span>
                </div>
                <h3 id="modal-cleanup-confirm-title" class="modal-title mb-0">@L["Settings_CleanupConfirmTitle"]</h3>
            </div>
            <p class="text-sm text-on-surface-variant">@L["Settings_CleanupConfirmMessage", _pendingCleanupMonths]</p>
            <div class="modal-actions mt-4">
                <button type="button" class="btn-secondary" @onclick="CancelCleanupConfirm">@L["Common_Cancel"]</button>
                <button type="button"
                        class="rounded-xl px-4 py-2 text-sm font-medium text-white transition-colors"
                        style="background: var(--color-error);"
                        disabled="@_isCleaningUp"
                        @onclick="ConfirmCleanupAsync">@L["Settings_CleanupConfirmAction"]</button>
            </div>
        </div>
    </div>
}

@page "/login"
@attribute [AllowAnonymous]
@layout AuthLayout

<PageTitle>@L["Login_PageTitle"] - AnyDrop</PageTitle>

<div class="login-card">
    @* Logo *@
    <div class="flex justify-center mb-6">
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl login-logo-icon">
            <span class="material-symbols-outlined text-white login-logo-symbol">sync_alt</span>
        </div>
    </div>

    @* 标题 *@
    <div class="text-center mb-8">
        <h1 class="font-headline text-3xl font-extrabold mb-1 login-title">AnyDrop</h1>
        <p class="text-sm login-subtitle">@L["Login_Subtitle"]</p>
    </div>

    <p class="text-sm text-center mb-5 login-prompt">@L["Login_Prompt"]</p>

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="login" @onsubmit:preventDefault class="space-y-4">
        <DataAnnotationsValidator />

        @* 密码输入框 *@
        <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined login-input-icon">lock</span>
            <InputText @bind-Value="_model.Password"
                       type="password"
                       class="login-input w-full pl-11 pr-4 py-3 rounded-2xl text-sm"
                       placeholder="@L["Login_PasswordPlaceholder"]"
                       aria-label="@L["Login_PasswordAriaLabel"]" />
        </div>

        @* 错误提示 *@
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="login-error flex items-center gap-2 rounded-xl px-4 py-2.5">
                <span class="material-symbols-outlined text-sm login-error-icon">error</span>
                <p class="text-sm login-error-text">@_error</p>
            </div>
        }

        @* 登录按钮 *@
        <button type="submit"
                class="login-btn w-full py-3 rounded-2xl text-sm font-semibold transition-all"
                disabled="@(_submitting || !_isInteractive)">
            @if (_submitting)
            {
                <span class="flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined animate-spin text-sm login-spinner-icon">progress_activity</span>
                    @L["Login_Submitting"]
                </span>
            }
            else
            {
                <span>@L["Login_Submit"]</span>
            }
        </button>
    </EditForm>
</div>

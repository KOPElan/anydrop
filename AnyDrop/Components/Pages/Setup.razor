@page "/setup"
@attribute [AllowAnonymous]
@layout AuthLayout

<PageTitle>@L["Setup_PageTitle"] - AnyDrop</PageTitle>

<section class="mx-auto mt-16 w-full max-w-md rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h1 class="text-xl font-bold">@L["Setup_Title"]</h1>
    <p class="mt-1 text-sm text-gray-500">@L["Setup_Subtitle"]</p>

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="setup" @onsubmit:preventDefault class="mt-6 space-y-4">
        <DataAnnotationsValidator />
        <div>
            <label class="mb-1 block text-sm font-medium">@L["Setup_Nickname"]</label>
            <InputText @bind-Value="_model.Nickname" class="w-full rounded-xl border border-gray-300 px-3 py-2" />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">@L["Setup_Password"]</label>
            <InputText @bind-Value="_model.Password" type="password" class="w-full rounded-xl border border-gray-300 px-3 py-2" />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium">@L["Setup_ConfirmPassword"]</label>
            <InputText @bind-Value="_model.ConfirmPassword" type="password" class="w-full rounded-xl border border-gray-300 px-3 py-2" />
        </div>
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="text-sm text-red-600">@_error</p>
        }
        <button type="submit" class="w-full rounded-xl bg-blue-600 px-4 py-2 font-medium text-white" disabled="@(_submitting || !_isInteractive)">@L["Setup_Submit"]</button>
    </EditForm>
</section>

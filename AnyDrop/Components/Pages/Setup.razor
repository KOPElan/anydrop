@page "/setup"
@attribute [AllowAnonymous]
@layout AuthLayout

<PageTitle>@L["Setup_PageTitle"] - AnyDrop</PageTitle>

<section class="setup-card mx-auto mt-16 w-full max-w-md">
    <h1 class="setup-title">@L["Setup_Title"]</h1>
    <p class="setup-subtitle mt-1 text-sm">@L["Setup_Subtitle"]</p>

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="setup" @onsubmit:preventDefault class="mt-6 space-y-4">
        <DataAnnotationsValidator />
        <div>
            <label class="auth-label mb-1 block text-sm font-medium">@L["Setup_Nickname"]</label>
            <InputText @bind-Value="_model.Nickname" class="auth-input w-full rounded-xl px-3 py-2" />
        </div>
        <div>
            <label class="auth-label mb-1 block text-sm font-medium">@L["Setup_Password"]</label>
            <InputText @bind-Value="_model.Password" type="password" class="auth-input w-full rounded-xl px-3 py-2" />
        </div>
        <div>
            <label class="auth-label mb-1 block text-sm font-medium">@L["Setup_ConfirmPassword"]</label>
            <InputText @bind-Value="_model.ConfirmPassword" type="password" class="auth-input w-full rounded-xl px-3 py-2" />
        </div>
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="auth-error-text text-sm">@_error</p>
        }
        <button type="submit" class="auth-submit-btn w-full rounded-xl px-4 py-2 font-medium" disabled="@(_submitting || !_isInteractive)">@L["Setup_Submit"]</button>
    </EditForm>
</section>

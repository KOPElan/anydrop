@page "/setup"
@attribute [AllowAnonymous]
@layout AuthLayout

<PageTitle>初始化 - AnyDrop</PageTitle>

<div class="login-card">
    @* Logo *@
    <div class="flex justify-center mb-6">
        <div class="flex h-16 w-16 items-center justify-center rounded-2xl login-logo-icon">
            <span class="material-symbols-outlined text-white" style="font-size: 32px; font-variation-settings: 'FILL' 1;">sync_alt</span>
        </div>
    </div>

    @* 标题 *@
    <div class="text-center mb-8">
        <h1 class="font-headline text-3xl font-extrabold mb-1" style="color: var(--color-on-surface);">AnyDrop</h1>
        <p class="text-sm" style="color: var(--color-outline);">首次配置 · 创建管理员账号</p>
    </div>

    @* 分割线 *@
    <div class="mb-6" style="border-top: 1px solid var(--color-outline-variant);"></div>

    <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="setup" @onsubmit:preventDefault class="space-y-4">
        <DataAnnotationsValidator />

        @* 昵称 *@
        <div>
            <label class="mb-1.5 block text-sm font-medium" style="color: var(--color-on-surface-variant);">昵称</label>
            <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined" style="font-size: 18px; color: var(--color-outline);">person</span>
                <InputText @bind-Value="_model.Nickname"
                           class="login-input w-full pl-11 pr-4 py-3 rounded-2xl text-sm"
                           placeholder="请输入昵称"
                           aria-label="昵称" />
            </div>
        </div>

        @* 密码 *@
        <div>
            <label class="mb-1.5 block text-sm font-medium" style="color: var(--color-on-surface-variant);">密码</label>
            <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined" style="font-size: 18px; color: var(--color-outline);">lock</span>
                <InputText @bind-Value="_model.Password"
                           type="password"
                           class="login-input w-full pl-11 pr-4 py-3 rounded-2xl text-sm"
                           placeholder="请输入密码"
                           aria-label="密码" />
            </div>
        </div>

        @* 确认密码 *@
        <div>
            <label class="mb-1.5 block text-sm font-medium" style="color: var(--color-on-surface-variant);">确认密码</label>
            <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined" style="font-size: 18px; color: var(--color-outline);">lock_reset</span>
                <InputText @bind-Value="_model.ConfirmPassword"
                           type="password"
                           class="login-input w-full pl-11 pr-4 py-3 rounded-2xl text-sm"
                           placeholder="请再次输入密码"
                           aria-label="确认密码" />
            </div>
        </div>

        @* 错误提示 *@
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="flex items-center gap-2 rounded-xl px-4 py-2.5" style="background: var(--color-error-container); border: 1px solid var(--color-error);">
                <span class="material-symbols-outlined text-sm" style="font-size: 16px; color: var(--color-error);">error</span>
                <p class="text-sm" style="color: var(--color-error);">@_error</p>
            </div>
        }

        @* 提交按钮 *@
        <button type="submit"
                class="login-btn w-full py-3 rounded-2xl text-sm font-semibold transition-all"
                disabled="@(_submitting || !_isInteractive)">
            @if (_submitting)
            {
                <span class="flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined animate-spin text-sm" style="font-size: 16px;">progress_activity</span>
                    创建中…
                </span>
            }
            else
            {
                <span>创建并登录</span>
            }
        </button>
    </EditForm>
</div>

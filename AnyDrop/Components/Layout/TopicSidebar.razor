@* 侧边栏主体 *@
<div class="flex h-full flex-col">

    @* 品牌标题 + 新建按钮 *@
    <div class="flex items-center justify-between p-6">
        <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-xl shadow-lg"
                 style="background: linear-gradient(135deg, #6366f1, #3b82f6); box-shadow: 0 4px 12px rgba(99,102,241,0.35);">
                <span class="material-symbols-outlined text-white" style="font-size: 18px; font-variation-settings: 'FILL' 1;">sync_alt</span>
            </div>
            <span class="font-headline text-xl font-extrabold tracking-tight" style="color: var(--color-on-surface);">AnyDrop</span>
        </div>
        @* 新建主题按钮（触发布局层 Modal，避免 backdrop-filter 层叠上下文限制）*@
        <button type="button"
            aria-label="@L["Layout_CreateTopicTitle"]"
                class="glass-btn flex items-center justify-center p-2.5 rounded-xl transition-all active:scale-90"
                style="color: var(--color-on-surface-variant);"
                @onclick="() => OpenCreateTopicModal?.Invoke()">
            <span class="material-symbols-outlined" style="font-size: 18px;">add</span>
        </button>
    </div>

    @* ── 会话主题 ─────────────────────────── *@
    <div class="px-4 mb-4">
        <p class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--color-outline);">@L["Sidebar_RecentSessions"]</p>
    </div>

    @* 主题列表 *@
    <div class="flex-1 overflow-y-auto px-4 pb-2 sidebar-scroll">
        @if (_topics.Count == 0)
        {
            <div class="sidebar-empty-state mx-1">@L["Sidebar_NoTopics"]</div>
        }
        else
        {
            <div id="topic-list" class="space-y-1 mb-2">
                @foreach (var topic in _topics)
                {
                    var isActive = _selectedTopicId == topic.Id;
                    var hasUnread = _unreadTopicIds.Contains(topic.Id);
                    <button
                        type="button"
                        @key="topic.Id"
                        data-id="@topic.Id"
                        class="@(isActive ? "sidebar-item sidebar-item--active" : "sidebar-item")"
                        @onclick="() => SelectTopicAsync(topic.Id)">
                        @* 图标容器 *@
                        <div class="sidebar-item__icon">
                            <span class="material-symbols-outlined text-sm"
                                  style="font-variation-settings: 'FILL' @(isActive ? "1" : "0");">
                                @topic.Icon
                            </span>
                        </div>
                        @* 文本内容 *@
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center justify-between gap-1">
                                <span class="sidebar-item__name font-semibold">@topic.Name</span>
                                <div class="flex items-center gap-1 flex-shrink-0">
                                    @if (hasUnread)
                                    {
                                        <span class="inline-block w-2 h-2 rounded-full flex-shrink-0"
                                              style="background: linear-gradient(135deg, #6366f1, #3b82f6); box-shadow: 0 0 4px rgba(99,102,241,0.60);"></span>
                                    }
                                    @if (topic.LastMessageAt.HasValue)
                                    {
                                        <span class="sidebar-item__time">@topic.LastMessageAt.Value.ToLocalTime().ToString("HH:mm")</span>
                                    }
                                </div>
                            </div>
                            @* 激活时显示「Active now」；否则显示消息预览 *@
                            @if (isActive)
                            {
                                <p class="text-[11px] font-medium italic" style="color: #3b82f6;">@L["Sidebar_ActiveNow"]</p>
                            }
                            else
                            {
                                <div class="sidebar-item__preview @(hasUnread ? "font-semibold" : "")">
                                    @(topic.LastMessagePreview ?? L["Sidebar_NoMessages"])
                                </div>
                            }
                        </div>
                    </button>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="px-2 py-1 mt-1 text-xs" style="color: var(--color-error);">@_error</p>
        }

        @* ── 已归档入口（不参与排序，固定在列表末尾）─────── *@
        <button type="button"
                class="flex w-full items-center gap-2 rounded-2xl px-3 py-2.5 text-xs font-medium transition-colors mt-1"
                style="color: var(--color-on-surface-variant); border: 1px solid transparent;"
                @onclick="ToggleArchivedDropdownAsync">
            <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg" style="background: rgba(255,255,255,0.50);">
                <span class="material-symbols-outlined text-sm">archive</span>
            </div>
            <span class="flex-1 text-left">@L["Sidebar_Archived"]</span>
            <span class="material-symbols-outlined text-sm transition-transform @(_showArchivedDropdown ? "rotate-180" : "")">expand_more</span>
        </button>

        @* 归档主题下拉列表 *@
        @if (_showArchivedDropdown)
        {
            <div class="mt-1 space-y-0.5 pl-3">
                @if (_archivedTopics.Count == 0)
                {
                    <div class="px-3 py-2 text-xs" style="color: var(--color-outline);">@L["Sidebar_NoArchivedTopics"]</div>
                }
                else
                {
                    @foreach (var topic in _archivedTopics)
                    {
                        var isActive = _selectedTopicId == topic.Id;
                        <button
                            type="button"
                            class="@(isActive ? "sidebar-item sidebar-item--active" : "sidebar-item opacity-70")"
                            @onclick="() => SelectTopicAsync(topic.Id)">
                            <div class="sidebar-item__icon" style="width:2rem; height:2rem;">
                                <span class="material-symbols-outlined text-sm">archive</span>
                            </div>
                            <span class="sidebar-item__name text-xs">@topic.Name</span>
                        </button>
                    }
                }
            </div>
        }
    </div>

    @* ── 底部功能按钮 ────────────────────────── *@
    <div class="px-4 pb-6 pt-4 mt-auto space-y-1">
        <button type="button"
                class="flex w-full items-center gap-3 rounded-xl px-3 py-3 text-sm font-semibold transition-all hover:bg-white/40 active:scale-95"
                style="color: var(--color-on-surface-variant); border: 1px solid transparent;"
                @onclick="OpenSettings">
            <span class="material-symbols-outlined text-base" style="color: var(--color-outline);">settings</span>
            @L["Sidebar_Settings"]
        </button>
        <button type="button"
                class="flex w-full items-center gap-3 rounded-xl px-3 py-3 text-sm font-semibold transition-all hover:bg-red-50/50 active:scale-95"
                style="color: var(--color-error); border: 1px solid transparent;"
                @onclick="LogoutAsync">
            <span class="material-symbols-outlined text-base">logout</span>
            @L["Sidebar_Logout"]
        </button>
    </div>
</div>

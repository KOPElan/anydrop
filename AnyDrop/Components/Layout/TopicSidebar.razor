@* 侧边栏主体 *@
<div class="flex h-full flex-col" style="background-color: var(--color-surface-container-low);">

    @* 品牌标题 + 新建按钮 *@
    <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center gap-2.5">
            <div class="flex h-8 w-8 items-center justify-center rounded-xl" style="background: linear-gradient(135deg, #0050cb, #0066ff);">
                <span class="material-symbols-outlined text-white" style="font-size: 18px; font-variation-settings: 'FILL' 1;">sync_alt</span>
            </div>
            <span class="font-headline text-base font-extrabold" style="color: var(--color-on-surface);">AnyDrop</span>
        </div>
        @* 新建主题按钮移至品牌栏右侧 *@
        <button type="button"
                aria-label="新建主题"
                class="flex h-8 w-8 items-center justify-center rounded-lg transition-colors hover:bg-surface-container active:scale-90"
                style="color: var(--color-on-surface-variant);"
                @onclick="OpenCreateModal">
            <span class="material-symbols-outlined" style="font-size: 20px;">add</span>
        </button>
    </div>

    @* ── 会话主题 ─────────────────────────── *@
    <div class="px-5 pb-2">
        <p class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--color-outline);">Sessions</p>
    </div>

    @* 主题列表 *@
    <div class="flex-1 overflow-y-auto px-3 pb-2">
        @if (_topics.Count == 0)
        {
            <div class="sidebar-empty-state mx-1">暂无主题</div>
        }
        else
        {
            <div id="topic-list" class="space-y-0.5 mb-2">
                @foreach (var topic in _topics)
                {
                    var isActive = _selectedTopicId == topic.Id;
                    <button
                        type="button"
                        data-id="@topic.Id"
                        class="@(isActive ? "sidebar-item sidebar-item--active" : "sidebar-item")"
                        @onclick="() => SelectTopicAsync(topic.Id)">
                        <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' @(isActive ? "1" : "0"); color: @(topic.IsPinned ? "var(--color-primary)" : "inherit");">
                            @topic.Icon
                        </span>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center gap-1">
                                <span class="sidebar-item__name">@topic.Name</span>
                                @if (topic.LastMessageAt.HasValue)
                                {
                                    <span class="sidebar-item__time">@topic.LastMessageAt.Value.ToLocalTime().ToString("HH:mm")</span>
                                }
                            </div>
                            @* 状态徽标 *@
                            @if (isActive)
                            {
                                <span class="sidebar-item__status sidebar-item__status--active">active</span>
                            }
                            else if (topic.LastMessageAt.HasValue)
                            {
                                <span class="sidebar-item__status sidebar-item__status--unread">unread</span>
                            }
                        </div>
                    </button>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <p class="px-2 py-1 mt-1 text-xs" style="color: var(--color-error);">@_error</p>
        }

        @* ── 已归档入口（不参与排序，固定在列表末尾）─────── *@
        <button type="button"
                class="flex w-full items-center gap-2 rounded-xl px-4 py-2.5 text-xs font-medium transition-colors hover:bg-surface-container mt-1"
                style="color: var(--color-on-surface-variant);"
                @onclick="ToggleArchivedDropdownAsync">
            <span class="material-symbols-outlined text-base">archive</span>
            <span class="flex-1 text-left">已归档</span>
            <span class="material-symbols-outlined text-sm transition-transform @(_showArchivedDropdown ? "rotate-180" : "")">expand_more</span>
        </button>

        @* 归档主题下拉列表 *@
        @if (_showArchivedDropdown)
        {
            <div class="mt-0.5 space-y-0.5 pl-4">
                @if (_archivedTopics.Count == 0)
                {
                    <div class="px-3 py-2 text-xs" style="color: var(--color-outline);">暂无归档主题</div>
                }
                else
                {
                    @foreach (var topic in _archivedTopics)
                    {
                        var isActive = _selectedTopicId == topic.Id;
                        <button
                            type="button"
                            class="@(isActive ? "sidebar-item sidebar-item--active" : "sidebar-item opacity-70")"
                            @onclick="() => SelectTopicAsync(topic.Id)">
                            <span class="material-symbols-outlined text-base" style="font-size: 14px;">archive</span>
                            <span class="sidebar-item__name text-xs">@topic.Name</span>
                        </button>
                    }
                }
            </div>
        }
    </div>

    @* ── 在线设备（占位，无实际实现）──────────────── *@
    <div class="px-5 pt-4 pb-2">
        <p class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--color-outline);">Devices</p>
    </div>
    <div class="px-3 pb-4 space-y-0.5">
        <div class="flex items-center gap-3 px-3 py-2 rounded-xl text-on-surface-variant">
            <div class="relative">
                <span class="material-symbols-outlined text-lg">laptop_mac</span>
                <span class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full border-2 border-surface-container-low" style="background-color: #22c55e;"></span>
            </div>
            <div class="flex flex-col min-w-0">
                <span class="text-sm font-medium leading-none text-on-surface truncate">Current Device</span>
                <span class="text-[10px] font-bold mt-0.5" style="color: #22c55e;">Online</span>
            </div>
        </div>
        <div class="flex items-center gap-3 px-3 py-2 rounded-xl text-on-surface-variant opacity-50">
            <div class="relative">
                <span class="material-symbols-outlined text-lg">smartphone</span>
                <span class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full border-2 border-surface-container-low" style="background-color: var(--color-outline);"></span>
            </div>
            <div class="flex flex-col min-w-0">
                <span class="text-sm font-medium leading-none truncate">Phone</span>
                <span class="text-[10px] font-bold mt-0.5">Offline</span>
            </div>
        </div>
    </div>

    @* ── 底部功能按钮 ────────────────────────── *@
    <div class="px-3 pb-4 pt-2 mt-auto space-y-0.5 border-t" style="border-color: var(--color-outline-variant);">
        <button type="button"
                class="flex w-full items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition-colors hover:bg-surface-container"
                style="color: var(--color-on-surface-variant);"
                @onclick="OpenSettings">
            <span class="material-symbols-outlined text-base">settings</span>
            Settings
        </button>
        <button type="button"
                class="flex w-full items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition-colors hover:bg-error-container/20"
                style="color: var(--color-error);"
                @onclick="LogoutAsync">
            <span class="material-symbols-outlined text-base">logout</span>
            Logout
        </button>
    </div>
</div>

@* 新建主题 Modal *@
@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modal-create-topic-title" @onclick:stopPropagation>
            <h3 id="modal-create-topic-title" class="modal-title">新建主题</h3>
            <input
                id="topic-name-input"
                aria-label="主题名称"
                class="mt-3 w-full rounded-xl border px-3 py-2.5 text-sm outline-none transition focus:ring-2 focus:ring-primary/30"
                style="border-color: var(--color-outline-variant); background: var(--color-surface); color: var(--color-on-surface);"
                placeholder="输入主题名称（最多100字）"
                maxlength="100"
                @bind="_newTopicName"
                @ref="_modalInputRef" />
            @if (!string.IsNullOrWhiteSpace(_modalError))
            {
                <p class="mt-1 text-xs" style="color: var(--color-error);">@_modalError</p>
            }
            <div class="modal-actions mt-4">
                <button type="button" class="btn-secondary" @onclick="CloseCreateModal">取消</button>
                <button type="button" class="btn-primary" @onclick="CreateTopicAsync">创建</button>
            </div>
        </div>
    </div>
}

@* 侧边栏主体 *@
<div class="flex h-full flex-col" style="background-color: var(--color-surface-container-low);">

    @* 品牌标题 *@
    <div class="flex items-center gap-2.5 px-5 py-5">
        <div class="flex h-8 w-8 items-center justify-center rounded-xl" style="background: linear-gradient(135deg, #0050cb, #0066ff);">
            <span class="material-symbols-outlined text-white" style="font-size: 18px; font-variation-settings: 'FILL' 1;">sync_alt</span>
        </div>
        <span class="font-headline text-base font-extrabold" style="color: var(--color-on-surface);">AnyDrop</span>
    </div>

    @* 分区标题 *@
    <div class="px-5 pb-2">
        <p class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--color-outline);">会话主题</p>
    </div>

    @* 主题列表 *@
    @if (_topics.Count == 0)
    {
        <div class="sidebar-empty-state mx-3">暂无主题</div>
    }
    else
    {
        <div id="topic-list" class="flex-1 overflow-y-auto space-y-0.5 px-3 pb-2">
            @foreach (var topic in _topics)
            {
                var isActive = _selectedTopicId == topic.Id;
                <button
                    type="button"
                    data-id="@topic.Id"
                    class="@(isActive ? "sidebar-item sidebar-item--active" : "sidebar-item")"
                    @onclick="() => SelectTopicAsync(topic.Id)">
                    <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' @(isActive ? "1" : "0"); color: @(topic.IsPinned ? "var(--color-primary)" : "inherit");">
                        @(topic.IsPinned ? "bookmark" : "chat_bubble")
                    </span>
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-1">
                            <span class="sidebar-item__name">@topic.Name</span>
                            @if (topic.LastMessageAt.HasValue)
                            {
                                <span class="sidebar-item__time">@topic.LastMessageAt.Value.ToLocalTime().ToString("HH:mm")</span>
                            }
                        </div>
                        <div class="sidebar-item__preview">
                            @(topic.LastMessagePreview ?? "暂无消息")
                        </div>
                    </div>
                </button>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="px-4 py-2 text-xs" style="color: var(--color-error);">@_error</p>
    }

    @* 新建主题按钮 *@
    <div class="p-3 border-t" style="border-color: var(--color-outline-variant);">
        <button type="button"
                aria-label="新建主题"
                class="flex w-full items-center gap-2 rounded-xl border border-dashed px-4 py-2.5 text-sm font-medium transition-colors hover:bg-surface-container"
                style="border-color: var(--color-outline-variant); color: var(--color-on-surface-variant);"
                @onclick="OpenCreateModal">
            <span class="material-symbols-outlined text-base">add</span>
            新建主题
        </button>
    </div>
</div>

@* 新建主题 Modal *@
@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="modal-create-topic-title" @onclick:stopPropagation>
            <h3 id="modal-create-topic-title" class="modal-title">新建主题</h3>
            <input
                id="topic-name-input"
                aria-label="主题名称"
                class="mt-3 w-full rounded-xl border px-3 py-2.5 text-sm outline-none transition focus:ring-2 focus:ring-primary/30"
                style="border-color: var(--color-outline-variant); background: var(--color-surface); color: var(--color-on-surface);"
                placeholder="输入主题名称（最多100字）"
                maxlength="100"
                @bind="_newTopicName"
                @ref="_modalInputRef" />
            @if (!string.IsNullOrWhiteSpace(_modalError))
            {
                <p class="mt-1 text-xs" style="color: var(--color-error);">@_modalError</p>
            }
            <div class="modal-actions mt-4">
                <button type="button" class="btn-secondary" @onclick="CloseCreateModal">取消</button>
                <button type="button" class="btn-primary" @onclick="CreateTopicAsync">创建</button>
            </div>
        </div>
    </div>
}

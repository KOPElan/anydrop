@* 侧边栏主体 *@
<div class="flex h-full flex-col">
    @* 标题栏 *@
    <div class="flex items-center justify-between px-4 py-3">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-400">主题会话</h2>
        <button type="button"
                aria-label="新建主题"
                class="rounded-md p-1 text-gray-400 transition-colors hover:bg-gray-200 hover:text-indigo-600"
                @onclick="OpenCreateModal">
            @* Heroicon: plus-circle outline *@
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
            </svg>
        </button>
    </div>

    @* 主题列表 *@
    @if (_topics.Count == 0)
    {
        <div class="sidebar-empty-state mx-3">暂无主题</div>
    }
    else
    {
        <div id="topic-list" class="flex-1 overflow-y-auto space-y-0.5 px-2 pb-2">
            @foreach (var topic in _topics)
            {
                var isActive = _selectedTopicId == topic.Id;
                <button
                    type="button"
                    data-id="@topic.Id"
                    class="@(isActive ? "sidebar-item sidebar-item--active" : "sidebar-item")"
                    @onclick="() => SelectTopicAsync(topic.Id)">
                    <div class="sidebar-item__header">
                        <span class="sidebar-item__name">@topic.Name</span>
                        @if (topic.LastMessageAt.HasValue)
                        {
                            <span class="sidebar-item__time">@topic.LastMessageAt.Value.ToLocalTime().ToString("HH:mm")</span>
                        }
                    </div>
                    <div class="sidebar-item__preview">
                        @(topic.LastMessagePreview ?? "暂无消息")
                    </div>
                </button>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <p class="px-4 py-2 text-xs text-red-600">@_error</p>
    }
</div>

@* 新建主题 Modal *@
@if (_showCreateModal)
{
    <div class="modal-overlay" @onclick="CloseCreateModal">
        <div class="modal-content" @onclick:stopPropagation>
            <h3 class="modal-title">新建主题</h3>
            <input
                class="mt-3 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none ring-indigo-200 transition focus:ring"
                placeholder="输入主题名称（最多100字）"
                maxlength="100"
                @bind="_newTopicName"
                @ref="_modalInputRef" />
            @if (!string.IsNullOrWhiteSpace(_modalError))
            {
                <p class="mt-1 text-xs text-red-600">@_modalError</p>
            }
            <div class="modal-actions mt-4">
                <button type="button" class="btn-secondary" @onclick="CloseCreateModal">取消</button>
                <button type="button" class="btn-primary" @onclick="CreateTopicAsync">创建</button>
            </div>
        </div>
    </div>
}

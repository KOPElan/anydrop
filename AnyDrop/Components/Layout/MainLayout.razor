@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="app-sidebar">
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
            <FluentLabel Typography="Typography.PaneHeader">AnyDrop</FluentLabel>
            <FluentDivider />
            <FluentNavMenu>
                <FluentNavLink Href="/" Match="NavLinkMatch.All" IconStart="@(new Icons.Regular.Size20.Chat())">
                    实时共享
                </FluentNavLink>
            </FluentNavMenu>
        </FluentStack>
    </aside>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

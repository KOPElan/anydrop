@inherits LayoutComponentBase
@implements IDisposable
@inject ITopicStateService TopicStateService

<div class="app-shell">
    @* 移动端遮罩层（半透明磨砂，点击关闭侧边栏）*@
    @if (_sidebarMobileOpen)
    {
        <div class="sidebar-mobile-backdrop" @onclick="CloseMobileSidebar"></div>
    }

    <aside class="sidebar border-r border-gray-200 bg-[var(--color-sidebar)] @(_sidebarMobileOpen ? "sidebar--mobile-open" : "")">
        <TopicSidebar />
    </aside>

    <main class="flex flex-col overflow-hidden">
        <CascadingValue Value="TopicStateService.SelectedTopicId">
            <CascadingValue Value="@((Action)ToggleMobileSidebar)" Name="ToggleMobileSidebar">
                @Body
            </CascadingValue>
        </CascadingValue>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _sidebarMobileOpen;

    protected override void OnInitialized()
    {
        TopicStateService.SelectedTopicChanged += HandleSelectedTopicChanged;
    }

    private void ToggleMobileSidebar()
    {
        _sidebarMobileOpen = !_sidebarMobileOpen;
        StateHasChanged();
    }

    private void CloseMobileSidebar()
    {
        _sidebarMobileOpen = false;
        StateHasChanged();
    }

    private async Task HandleSelectedTopicChanged()
    {
        // 移动端选中主题后自动关闭侧边栏
        _sidebarMobileOpen = false;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TopicStateService.SelectedTopicChanged -= HandleSelectedTopicChanged;
    }
}

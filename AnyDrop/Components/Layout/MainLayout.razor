@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar border-r border-gray-200 bg-[var(--color-sidebar)]">
        <TopicSidebar OnTopicSelected="HandleTopicSelectedAsync" />
    </aside>

    <main class="flex flex-col overflow-hidden">
        <CascadingValue Value="_selectedTopicId">
            @Body
        </CascadingValue>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private Guid? _selectedTopicId;

    private Task HandleTopicSelectedAsync(Guid? topicId)
    {
        // 避免值未变化时触发不必要的级联更新，防止 Home 重复加载消息
        if (_selectedTopicId == topicId) return Task.CompletedTask;
        _selectedTopicId = topicId;
        return Task.CompletedTask;
    }
}

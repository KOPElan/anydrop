@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar bg-[var(--color-sidebar)] p-4">
        <TopicSidebar OnTopicSelected="HandleTopicSelectedAsync" />
    </aside>

    <main class="flex flex-col overflow-hidden">
        <CascadingValue Value="_selectedTopicId">
            @Body
        </CascadingValue>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private Guid? _selectedTopicId;

    private Task HandleTopicSelectedAsync(Guid? topicId)
    {
        _selectedTopicId = topicId;
        return Task.CompletedTask;
    }
}
